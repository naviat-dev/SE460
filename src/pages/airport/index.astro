---
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Airport Details</title>
    <style>
      :root {
        --bg: #f7f4ee;
        --surface: #ffffff;
        --surface-soft: #f4f7fb;
        --text-main: #0f2334;
        --text-muted: #4a5f74;
        --border: rgba(15, 35, 52, 0.18);
        --casual: #2f6f91;
        --expert: #b9432a;
        --expert-soft: rgba(185, 67, 42, 0.12);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background:
          radial-gradient(circle at 90% 10%, #f9e4d9, transparent 28%),
          radial-gradient(circle at 8% 78%, #d9ebf4, transparent 34%),
          var(--bg);
        color: var(--text-main);
        font-family: "Segoe UI", "Trebuchet MS", "Gill Sans", sans-serif;
        min-height: 100vh;
      }

      .shell {
        width: min(980px, 92vw);
        margin: 0 auto;
        padding: 2.3rem 0 2.5rem;
      }

      .topbar {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: center;
        margin-bottom: 1.2rem;
      }

      .home-link {
        text-decoration: none;
        color: var(--casual);
        font-weight: 700;
      }

      .home-link:hover,
      .home-link:focus-visible {
        text-decoration: underline;
      }

      .card {
        background: rgba(255, 255, 255, 0.88);
        border: 1px solid var(--border);
        border-radius: 18px;
        padding: 1.25rem;
        box-shadow: 0 20px 40px rgba(30, 45, 61, 0.08);
      }

      h1 {
        margin: 0;
        font-size: clamp(1.9rem, 4vw, 2.8rem);
      }

      .subtitle {
        color: var(--text-muted);
        margin: 0.35rem 0 0;
      }

      .controls {
        display: flex;
        gap: 0.6rem;
        margin: 1.1rem 0;
        flex-wrap: wrap;
      }

      .mode-button {
        border: 1px solid var(--border);
        background: var(--surface);
        color: var(--text-main);
        border-radius: 10px;
        padding: 0.65rem 0.9rem;
        font: inherit;
        cursor: pointer;
        font-weight: 700;
      }

      .mode-button:disabled {
        cursor: not-allowed;
        opacity: 0.7;
      }

      .mode-button.active-casual {
        background: rgba(47, 111, 145, 0.12);
        border-color: var(--casual);
        color: #154765;
      }

      .mode-button.active-expert {
        background: var(--expert-soft);
        border-color: var(--expert);
        color: #7f2917;
      }

      .status {
        min-height: 1.2rem;
        color: var(--text-muted);
        margin: 0.4rem 0 0;
      }

      .info-grid {
        margin-top: 1rem;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
        gap: 0.65rem;
      }

      .info-tile {
        border: 1px solid var(--border);
        border-radius: 10px;
        background: var(--surface-soft);
        padding: 0.7rem 0.8rem;
      }

      .label {
        color: var(--text-muted);
        font-size: 0.84rem;
        margin-bottom: 0.2rem;
      }

      .value {
        font-weight: 600;
        margin: 0;
      }

      .panel {
        margin-top: 1rem;
      }

      .panel h2 {
        margin: 0 0 0.55rem;
      }

      .stack {
        display: grid;
        gap: 0.9rem;
      }

      .subpanel {
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 0.8rem;
        background: #ffffff;
      }

      .subpanel h3 {
        margin: 0 0 0.5rem;
      }

      .list {
        margin: 0;
        padding-left: 1.1rem;
        display: grid;
        gap: 0.45rem;
      }

      .notam-list {
        margin: 0;
        padding: 0;
        list-style: none;
        display: grid;
        gap: 0.6rem;
      }

      .notam-item {
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 0.65rem;
        background: #fff;
      }

      .notam-id {
        font-weight: 700;
        margin: 0 0 0.4rem;
      }

      .notam-message {
        margin: 0;
        white-space: pre-wrap;
      }

      .warning-list {
        margin: 0;
        padding-left: 1rem;
        color: #7f2917;
      }

      table {
        width: 100%;
        border-collapse: collapse;
      }

      th,
      td {
        text-align: left;
        border-bottom: 1px solid rgba(15, 35, 52, 0.13);
        padding: 0.45rem 0.25rem;
      }

      .hidden {
        display: none;
      }

      @media (max-width: 640px) {
        .shell {
          padding-top: 1rem;
        }

        .card {
          padding: 1rem;
        }
      }
    </style>
  </head>
  <body>
    <main class="shell">
      <div class="topbar">
        <a href="../" class="home-link">Back To Search</a>
      </div>

      <section class="card">
        <h1 id="airport-title">Loading airport...</h1>
        <p id="airport-subtitle" class="subtitle">Preparing airport data...</p>

        <div class="controls">
          <button id="casual-button" class="mode-button active-casual" type="button" aria-pressed="true">
            Casual
          </button>
          <button id="expert-button" class="mode-button" type="button" aria-pressed="false">
            Expert
          </button>
        </div>

        <p id="mode-status" class="status" aria-live="polite"></p>

        <section id="casual-panel" class="panel">
          <h2>Casual Overview</h2>
          <div id="casual-grid" class="info-grid"></div>
        </section>

        <section id="expert-panel" class="panel hidden">
          <h2>Expert Details</h2>
          <div class="stack">
            <section class="subpanel">
              <h3>Frequencies</h3>
              <div id="frequency-container">Loading frequencies...</div>
            </section>

            <section class="subpanel">
              <h3>SIDs</h3>
              <ul id="sid-list" class="list"></ul>
            </section>

            <section class="subpanel">
              <h3>STARs</h3>
              <ul id="star-list" class="list"></ul>
            </section>

            <section class="subpanel">
              <h3>NOTAMs</h3>
              <ul id="notam-list" class="notam-list"></ul>
              <p id="notam-fallback" class="status hidden"></p>
            </section>

            <section class="subpanel">
              <h3>Expert Warnings</h3>
              <ul id="warning-list" class="warning-list"></ul>
            </section>
          </div>
        </section>
      </section>
    </main>

    <script type="module">
      import Papa from "papaparse";

      const AIRPORTS_CSV_URL = "https://davidmegginson.github.io/ourairports-data/airports.csv";
      const FREQUENCIES_CSV_URL = "https://davidmegginson.github.io/ourairports-data/airport-frequencies.csv";
      const FLIGHTPLAN_AIRPORT_URL = "https://api.flightplandatabase.com/nav/airport";
      const AVIATION_API_CHARTS_URL = "https://api.aviationapi.com/v1/charts";
      const NOTAM_SEARCH_URL = "https://notams.aim.faa.gov/notamSearch/nsapp.html#/";
      const PROCEDURES_SEARCH_URL = "https://www.faa.gov/air_traffic/flight_info/aeronav/procedures/";

      const queryIdent = String(new URLSearchParams(window.location.search).get("ident") || "")
        .trim()
        .toUpperCase();

      const title = document.querySelector("#airport-title");
      const subtitle = document.querySelector("#airport-subtitle");
      const statusText = document.querySelector("#mode-status");
      const casualButton = document.querySelector("#casual-button");
      const expertButton = document.querySelector("#expert-button");
      const casualPanel = document.querySelector("#casual-panel");
      const expertPanel = document.querySelector("#expert-panel");
      const casualGrid = document.querySelector("#casual-grid");
      const frequencyContainer = document.querySelector("#frequency-container");
      const sidList = document.querySelector("#sid-list");
      const starList = document.querySelector("#star-list");
      const notamList = document.querySelector("#notam-list");
      const notamFallback = document.querySelector("#notam-fallback");
      const warningList = document.querySelector("#warning-list");

      const requiredElements = [
        title,
        subtitle,
        statusText,
        casualButton,
        expertButton,
        casualPanel,
        expertPanel,
        casualGrid,
        frequencyContainer,
        sidList,
        starList,
        notamList,
        notamFallback,
        warningList,
      ];

      if (requiredElements.some((element) => !element)) {
        throw new Error("Airport page is missing required UI containers.");
      }

      const clean = (value) => String(value || "").trim();
      const escapeText = (value) =>
        String(value)
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#39;");

      const parseNumber = (value) => {
        const next = Number(clean(value));
        return Number.isFinite(next) ? next : null;
      };

      const parseFrequencyMhz = (value) => {
        const next = Number(value);
        return Number.isFinite(next) ? Number(next.toFixed(3)) : null;
      };

      const formatCoordinate = (value) =>
        typeof value === "number" && Number.isFinite(value) ? value.toFixed(5) : "Unknown";

      const formatElevation = (value) =>
        typeof value === "number" && Number.isFinite(value) ? `${Math.round(value)} ft` : "Unknown";

      const formatFrequency = (value) =>
        typeof value === "number" && Number.isFinite(value) ? `${value.toFixed(3)} MHz` : "Unknown";

      let currentAirport = null;
      let expertLoaded = false;
      let airportsPromise;
      let frequencyIndexPromise;

      const parseCsv = (csvText) =>
        Papa.parse(csvText, {
          header: true,
          skipEmptyLines: true,
          transformHeader: (header) => header.trim(),
        }).data;

      const loadAirports = async () => {
        if (!airportsPromise) {
          airportsPromise = (async () => {
            const response = await fetch(AIRPORTS_CSV_URL);
            if (!response.ok) {
              throw new Error(`Airport data request failed with status ${response.status}.`);
            }

            const csvText = await response.text();
            return parseCsv(csvText)
              .map((row) => {
                const ident = clean(row.ident).toUpperCase();
                const name = clean(row.name);
                if (!ident || !name) {
                  return null;
                }

                return {
                  ident,
                  name,
                  type: clean(row.type),
                  municipality: clean(row.municipality),
                  isoCountry: clean(row.iso_country),
                  isoRegion: clean(row.iso_region),
                  elevationFt: parseNumber(row.elevation_ft),
                  latitudeDeg: parseNumber(row.latitude_deg),
                  longitudeDeg: parseNumber(row.longitude_deg),
                  scheduledService: clean(row.scheduled_service).toLowerCase() === "yes",
                  iataCode: clean(row.iata_code).toUpperCase(),
                  gpsCode: clean(row.gps_code).toUpperCase(),
                  localCode: clean(row.local_code).toUpperCase(),
                };
              })
              .filter(Boolean);
          })();
        }

        return airportsPromise;
      };

      const loadFrequencyIndex = async () => {
        if (!frequencyIndexPromise) {
          frequencyIndexPromise = (async () => {
            const response = await fetch(FREQUENCIES_CSV_URL);
            if (!response.ok) {
              return new Map();
            }

            const csvText = await response.text();
            const rows = parseCsv(csvText);
            const map = new Map();

            for (const row of rows) {
              const ident = clean(row.airport_ident).toUpperCase();
              if (!ident) {
                continue;
              }

              const next = {
                type: clean(row.type || "OTHER") || "OTHER",
                name: clean(row.description || "") || "Unknown",
                frequencyMhz: parseFrequencyMhz(parseNumber(row.frequency_mhz)),
              };

              const existing = map.get(ident) || [];
              existing.push(next);
              map.set(ident, existing);
            }

            return map;
          })();
        }

        return frequencyIndexPromise;
      };

      const dedupeFrequencies = (frequencies) => {
        const seen = new Set();
        const deduped = [];

        for (const entry of frequencies) {
          const key = `${entry.type}|${entry.name}|${String(entry.frequencyMhz)}`;
          if (seen.has(key)) {
            continue;
          }

          seen.add(key);
          deduped.push(entry);
        }

        return deduped.sort((a, b) => {
          if (a.frequencyMhz !== null && b.frequencyMhz !== null && a.frequencyMhz !== b.frequencyMhz) {
            return a.frequencyMhz - b.frequencyMhz;
          }

          return String(a.type).localeCompare(String(b.type));
        });
      };

      const dedupeCharts = (charts) => {
        const seen = new Set();
        const deduped = [];

        for (const chart of charts) {
          const key = `${chart.chartCode}|${chart.chartName}|${chart.pdfPath}`;
          if (seen.has(key)) {
            continue;
          }

          seen.add(key);
          deduped.push(chart);
        }

        return deduped.sort((a, b) => String(a.chartName).localeCompare(String(b.chartName)));
      };

      const setMode = (mode) => {
        const casual = mode === "casual";

        casualPanel.classList.toggle("hidden", !casual);
        expertPanel.classList.toggle("hidden", casual);

        casualButton.classList.toggle("active-casual", casual);
        expertButton.classList.toggle("active-expert", !casual);

        casualButton.setAttribute("aria-pressed", String(casual));
        expertButton.setAttribute("aria-pressed", String(!casual));
      };

      const renderCasual = (airport) => {
        const tiles = [
          ["Name", airport.name || "Unknown"],
          ["ICAO", airport.ident || "Unknown"],
          ["IATA", airport.iataCode || "Unknown"],
          ["Country", airport.isoCountry || "Unknown"],
          ["Region", airport.isoRegion || "Unknown"],
          ["Municipality", airport.municipality || "Unknown"],
          ["Type", (airport.type || "Unknown").replaceAll("_", " ")],
          ["Scheduled Service", airport.scheduledService ? "Yes" : "No"],
          ["Elevation", formatElevation(airport.elevationFt)],
          ["Latitude", formatCoordinate(airport.latitudeDeg)],
          ["Longitude", formatCoordinate(airport.longitudeDeg)],
        ];

        casualGrid.innerHTML = tiles
          .map(
            ([label, value]) => `
              <article class="info-tile">
                <p class="label">${escapeText(label)}</p>
                <p class="value">${escapeText(value)}</p>
              </article>
            `,
          )
          .join("");
      };

      const renderFrequencyTable = (frequencies) => {
        if (!frequencies.length) {
          frequencyContainer.innerHTML = '<p class="status">No frequencies available.</p>';
          return;
        }

        const rows = frequencies
          .map(
            (entry) => `
              <tr>
                <td>${escapeText(entry.type || "OTHER")}</td>
                <td>${escapeText(entry.name || "Unknown")}</td>
                <td>${escapeText(formatFrequency(entry.frequencyMhz))}</td>
              </tr>
            `,
          )
          .join("");

        frequencyContainer.innerHTML = `
          <table>
            <thead>
              <tr>
                <th>Type</th>
                <th>Description</th>
                <th>Frequency</th>
              </tr>
            </thead>
            <tbody>${rows}</tbody>
          </table>
        `;
      };

      const renderChartList = (container, charts, emptyMessage) => {
        if (!charts.length) {
          container.innerHTML = `<li>${escapeText(emptyMessage)}</li>`;
          return;
        }

        container.innerHTML = charts
          .map((chart) => {
            const label = `${chart.chartCode || "PROC"} - ${chart.chartName || chart.pdfName || "Unnamed"}`;
            const href = escapeText(chart.pdfPath || "#");
            return `<li><a href="${href}" target="_blank" rel="noreferrer noopener">${escapeText(label)}</a></li>`;
          })
          .join("");
      };

      const renderNotams = () => {
        notamList.innerHTML = "";
        notamFallback.classList.remove("hidden");
        notamFallback.innerHTML = `Direct NOTAM API access is not publicly available from a static browser app. Use FAA NOTAM Search: <a href="${escapeText(NOTAM_SEARCH_URL)}" target="_blank" rel="noreferrer noopener">Open NOTAM Search</a>.`;
      };

      const renderWarnings = (warnings) => {
        if (!warnings.length) {
          warningList.innerHTML = "<li>No warnings reported.</li>";
          return;
        }

        warningList.innerHTML = warnings.map((warning) => `<li>${escapeText(warning)}</li>`).join("");
      };

      const findAirport = (airports, ident) => {
        const normalized = clean(ident).toUpperCase();
        if (!normalized) {
          return null;
        }

        return (
          airports.find((airport) => {
            const candidates = [airport.ident, airport.iataCode, airport.gpsCode, airport.localCode]
              .map((code) => clean(code).toUpperCase())
              .filter(Boolean);

            return candidates.includes(normalized);
          }) || null
        );
      };

      const loadAirport = async () => {
        if (!queryIdent) {
          throw new Error("No airport identifier was provided.");
        }

        statusText.textContent = `Loading ${queryIdent}...`;
        const airports = await loadAirports();
        const airport = findAirport(airports, queryIdent);

        if (!airport) {
          throw new Error(`No airport matched ${queryIdent}.`);
        }

        currentAirport = airport;
        title.textContent = `${airport.name} (${airport.ident})`;
        subtitle.textContent = `${airport.municipality || "Unknown city"}, ${airport.isoCountry || "Unknown country"}`;
        renderCasual(airport);
        statusText.textContent = "Casual mode shows core airport details.";
      };

      const getFlightPlanFrequencies = async (ident) => {
        try {
          const response = await fetch(`${FLIGHTPLAN_AIRPORT_URL}/${encodeURIComponent(ident)}`);
          if (!response.ok) {
            return [];
          }

          const payload = await response.json();
          const frequencies = Array.isArray(payload.frequencies) ? payload.frequencies : [];

          return frequencies.map((entry) => ({
            type: clean(entry.type || "OTHER") || "OTHER",
            name: clean(entry.name || "") || "Unknown",
            frequencyMhz: Number.isFinite(entry.frequency) ? Number((entry.frequency / 1_000_000).toFixed(3)) : null,
          }));
        } catch {
          return [];
        }
      };

      const getCsvFrequencies = async (ident) => {
        const index = await loadFrequencyIndex();
        return index.get(ident.toUpperCase()) || [];
      };

      const getProcedureCharts = async (ident) => {
        const warnings = [];

        try {
          const url = new URL(AVIATION_API_CHARTS_URL);
          url.searchParams.set("apt", ident);
          url.searchParams.set("chart", "STAR");

          const response = await fetch(url.toString());
          if (!response.ok) {
            warnings.push(`Procedure chart request failed with status ${response.status}.`);
            return { sids: [], stars: [], warnings };
          }

          const payload = await response.json();
          const rawCharts = payload[ident] || payload[ident.toUpperCase()] || [];
          const charts = rawCharts
            .map((chart) => ({
              chartCode: clean(chart.chart_code),
              chartName: clean(chart.chart_name),
              pdfName: clean(chart.pdf_name),
              pdfPath: clean(chart.pdf_path),
            }))
            .filter((chart) => chart.chartName && chart.pdfPath);

          return {
            sids: dedupeCharts(charts.filter((chart) => chart.chartCode === "DP")),
            stars: dedupeCharts(charts.filter((chart) => chart.chartCode === "STAR")),
            warnings,
          };
        } catch {
          warnings.push(
            "STAR/SID data is currently unavailable from the chart provider in browser-only mode. Use FAA procedures search.",
          );

          return {
            sids: [],
            stars: [],
            warnings,
          };
        }
      };

      const loadExpert = async () => {
        if (!currentAirport || expertLoaded) {
          return;
        }

        const ident = currentAirport.ident.toUpperCase();
        const warnings = [];

        statusText.textContent = "Loading expert data (SIDs/STARs, frequencies, NOTAMs)...";

        const [apiFrequencies, csvFrequencies, chartResult] = await Promise.all([
          getFlightPlanFrequencies(ident),
          getCsvFrequencies(ident),
          getProcedureCharts(ident),
        ]);

        const frequencies = dedupeFrequencies([...apiFrequencies, ...csvFrequencies]);
        if (!frequencies.length) {
          warnings.push("No frequency data was returned for this airport.");
        }

        if (!chartResult.sids.length && !chartResult.stars.length) {
          warnings.push(`No SID/STAR chart records were returned. Try FAA procedures search for ${ident}.`);
        }

        warnings.push(...chartResult.warnings);

        renderFrequencyTable(frequencies);
        renderChartList(
          sidList,
          chartResult.sids,
          `No SID charts found. Use FAA procedures search for ${ident}.`,
        );
        renderChartList(
          starList,
          chartResult.stars,
          `No STAR charts found. Use FAA procedures search for ${ident}.`,
        );

        renderNotams();
        warnings.push("NOTAMs require FAA authenticated data services in most cases. Using external FAA search link.");
        warnings.push(`FAA Procedures Search: ${PROCEDURES_SEARCH_URL}`);

        renderWarnings(warnings);
        expertLoaded = true;
        statusText.textContent = "Expert mode loaded.";
      };

      casualButton.addEventListener("click", () => {
        setMode("casual");
        if (currentAirport) {
          statusText.textContent = "Casual mode shows core airport details.";
        }
      });

      expertButton.addEventListener("click", async () => {
        setMode("expert");
        try {
          await loadExpert();
        } catch {
          statusText.textContent = "Expert data could not be loaded right now.";
          renderWarnings([
            "Expert data request failed. Confirm external providers are reachable and try again.",
          ]);
        }
      });

      setMode("casual");

      loadAirport().catch((error) => {
        title.textContent = "Airport Not Found";
        subtitle.textContent = "No airport record could be loaded.";
        statusText.textContent = "Return to search and select a valid airport code.";
        casualGrid.innerHTML =
          '<article class="info-tile"><p class="label">Hint</p><p class="value">Use an ICAO or IATA code from search results.</p></article>';
        expertButton.setAttribute("disabled", "true");
        renderWarnings([String(error && error.message ? error.message : "Unknown airport lookup error.")]);
      });
    </script>
  </body>
</html>
